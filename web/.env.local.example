# Handshake web/.env.local
#
# Copy this file to .env.local and fill in the values, or set them in the
# Vercel project settings for production.

# Required for the encrypted-handoff flow:
#   - POST /api/upload        stores ciphertext in Vercel Blob
#   - POST /api/key/store      stores the AES key (gated to release on onchain Released)
#   - GET  /api/blob/list      finds the ciphertext for a deal on unlock
#   - GET  /api/blob/sidecar   finds the IV sidecar for a deal on unlock
#
# Get a token by creating a Vercel Blob store:
#   https://vercel.com/dashboard/stores → Create Store → Blob → Copy "Read and Write" token
#
# Without this token, the landing page, create-deal flow, and deal view still work.
# Only the encrypted-handoff upload (step 4 of the demo) and key unlock (step 6) need it.
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
